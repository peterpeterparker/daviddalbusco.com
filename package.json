{
	"name": "daviddalbusco.com",
	"private": true,
	"description": "David Dal Busco - Freelance Software Engineer",
	"version": "5.2.0",
	"author": "David Dal Busco <david@fluster.io>",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"assets": "bun serve.assets.ts",
		"dev": "vite dev",
		"build:workaround": "node svelte.workaround.ts",
		"build": "vite build && pnpm build:workaround",
		"package": "svelte-kit package",
		"preview": "vite preview",
		"prepare": "svelte-kit sync",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"lint:fix": "prettier --check . && eslint . --fix",
		"format": "prettier --write .",
		"fmt": "pnpm run format"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@shikijs/langs": "^4.3.0",
		"@shikijs/themes": "^4.3.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.68.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/bun": "^1.3.14",
		"@types/eslint": "^9.6.1",
		"@types/node": "^26.0.1",
		"@types/remarkable": "^2.0.8",
		"@typescript-eslint/parser": "^8.62.0",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"kyushu-types": "0.2.1",
		"prettier": "^3.9.3",
		"prettier-plugin-organize-imports": "^4.3.0",
		"prettier-plugin-svelte": "^4.1.1",
		"remarkable": "^2.0.1",
		"sass-embedded": "^1.100.0",
		"shiki": "^4.3.0",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.0",
		"vite": "^8.1.0"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/peterpeterparker/daviddalbusco.com"
	},
	"bugs": {
		"url": "https://github.com/peterpeterparker/daviddalbusco.com/issues"
	},
	"overrides": {
		"cookie": "^0.7.0"
	},
	"dependencies": {
		"yawa-tracker": "0.0.5"
	},
	"engines": {
		"node": ">=24",
		"npm": "please use pnpm",
		"pnpm": ">=11"
	},
	"packageManager": "pnpm@11.7.0"
}
